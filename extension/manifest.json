{
  "manifest_version": 3,
  "name": "Supperware",
  "version": "0.1.0",
  "description": "Save recipes to Supperware from any webpage.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://supperware.sathyasekaran.com/*"],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  }
}
